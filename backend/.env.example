# Logging verbosity (error|warn|info|debug|trace)
RUST_LOG=info

# PostgreSQL connection string
DATABASE_URL=postgres://orbit:orbit@localhost:5432/orbit

# Redis (session cache / rate limiting)
REDIS_URL=redis://localhost:6379

# IMPORTANT: generate a long random value in production, e.g. openssl rand -hex 32
JWT_SECRET=change_me_use_a_long_random_value

# Server bind address
BIND_ADDRESS=127.0.0.1:8080

# Token / session lifetimes
ACCESS_TOKEN_TTL_SECS=86400
SESSION_TTL_HOURS=12

# WebRTC ICE servers
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER=

# Comma-separated allowed CORS origins. Leave empty to allow any (dev only).
# Example for an unpacked extension: chrome-extension://<extension-id>
CORS_ALLOWED_ORIGINS=
