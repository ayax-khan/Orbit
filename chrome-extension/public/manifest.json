{
  "manifest_version": 3,
  "name": "ORBIT Remote Desktop",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "alarms",
    "desktopCapture"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*",
    "ws://localhost:8080/*",
    "ws://127.0.0.1:8080/*"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
