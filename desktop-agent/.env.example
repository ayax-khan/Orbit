# Backend server address
ORBIT_BACKEND_HOST=127.0.0.1:8080

# Session ID (optional - will poll for active session if not set)
ORBIT_SESSION_ID=

# ICE servers (comma-separated STUN/TURN URLs)
ORBIT_ICE_SERVERS=stun:stun.l.google.com:19302

# Capture dimensions
ORBIT_CAPTURE_WIDTH=1920
ORBIT_CAPTURE_HEIGHT=1080

# FPS bounds
ORBIT_MIN_FPS=30
ORBIT_MAX_FPS=60

# Device token (for authentication with backend)
# If not set, you must provide ORBIT_USER_TOKEN to register a new device
ORBIT_DEVICE_TOKEN=

# User token (for device registration - only needed if ORBIT_DEVICE_TOKEN is not set)
ORBIT_USER_TOKEN=

# Device name (optional - defaults to COMPUTERNAME-Agent)
ORBIT_DEVICE_NAME=

# Agent mode: 'host' (default) or 'client'
# host: waits for incoming connections (screen sharing)
# client: connects to another device (remote viewing)
ORBIT_MODE=host

# For client mode: target device ID to connect to
ORBIT_HOST_DEVICE_ID=

# For client mode: your own device ID (must be registered)
ORBIT_CLIENT_DEVICE_ID=
